TELEGRAM_BOT_TOKEN=your-telegram-bot-token
X_API_KEY=your-x-bearer-token

# X usernames to monitor (no @ prefix)
WATCH_USERS=["elonmusk", "someuser"]
# Poll interval in minutes
POLL_INTERVAL=30
# Admin Telegram ID for error notifications
ADMIN_ID=

# Only deliver original tweets + quotes (exclude replies/retweets)
TWEETS_ONLY=true

LOG_LEVEL=INFO
